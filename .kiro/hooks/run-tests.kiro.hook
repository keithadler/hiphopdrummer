{
  "enabled": true,
  "name": "Run Tests",
  "description": "Runs node tests.js after any JS file is edited to catch regressions immediately",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.js"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "node tests.js",
    "timeout": 30
  }
}